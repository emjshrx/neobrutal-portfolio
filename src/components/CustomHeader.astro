---
import Hamburger from "./Hamburger.svelte";

const { currentPage } = Astro.props;
const generateLinkStyles = (page: string) =>
  currentPage === page
    ? "font-black"
    : " font-thin hover:opacity-75 opacity-50";
---

<header
  class="relative z-50 border-b-4 bg-white border-black flex items-center justify-between h-20 xl:px-20 p-5"
>
  <div class="flex font-medium text-2xl">
    <div>emj</div><div class="bg-black text-white">shrx</div>
  </div>
  <nav class="hidden md:flex text-xl items-center gap-8 lg:gap-10 xl:gap-14">
    <a href="/" class={generateLinkStyles("Home")}>Home</a>
    <a href="/about" class={generateLinkStyles("About")}>About</a>
    <a href="/blog/" class={generateLinkStyles("Blog")}>Blog</a>
    <a href="/learn/" class={generateLinkStyles("Learn")}>Learn</a>
    <a href="/projects" class={generateLinkStyles("Projects")}>Projects</a>
  </nav>
  <a
    class="hidden md:block text-2xl border-black border-2 rounded-2xl px-2 py-1 shadow-hard font-thin cursor-pointer hover:bg-black hover:text-white"
    href="mailTo:emjshrx@gmail.com"
  >
    Let's talk
  </a>
  <Hamburger client:visible currentPage={currentPage} />
</header>
