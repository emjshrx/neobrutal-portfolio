---
import Header from "../components/CustomHeader.astro";
import Loading from "../components/Loading.astro";
import "../styles/global.css";
import "../styles/blog.css";
export interface Props {
  title: string;
  currentPage: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title,
  currentPage,
  description = "The portfolio website of Emjshrx",
  image = "/favicon.ico",
  type = "website",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const completedPages = ["Home", "About"];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
  </head>
  <body class="flex bg-white flex-col lg:h-screen">
    <div
      id="loadingSplash"
      class={`${
        completedPages.includes(currentPage) ? "" : "hidden"
      } bg-green h-full w-full fixed z-50 flex items-center justify-center`}
    >
      <Loading />
    </div>
    <div class="grow-0 shrink-0 sticky top-0 z-40">
      <Header currentPage={currentPage} />
    </div>
    <div class="grow shrink min-h-0 z-0"><slot /></div>
  </body>
</html>
