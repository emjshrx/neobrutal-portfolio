---
import Layout from "./Layout.astro";

const { title, currentPage, description, image, type } = Astro.props;
---

<Layout
  title={title}
  currentPage={currentPage}
  description={description}
  image={image}
  type={type}
>
  <div class="lg:flex h-full">
    <div class="min-h-[85vh] lg:h-full lg:w-3/5 flex">
      <slot name="Left Content" />
    </div>
    <div class="h-screen lg:h-full lg:w-2/5"><slot name="Right Content" /></div>
  </div>
</Layout>
