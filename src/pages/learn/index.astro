---
import Layout from "../../layouts/Layout.astro";
import { learnSections } from "../../learnSections";
---

<Layout
  title="Learn"
  currentPage="Learn"
  description="Interactive lessons on Bitcoin, Liquid, and open protocols."
>
  <div class="max-w-3xl m-auto p-6 md:p-10">
    <h1 class="text-4xl mb-2">Learn</h1>
    <p class="text-lg opacity-70 mb-10">
      Pick a topic to start. Each section has lessons, references, and quizzes.
    </p>
    <div class="flex flex-col gap-4">
      {
        learnSections.map((section) => (
          <a
            href={`/learn/${section.slug}/`}
            class="block border-2 border-black rounded-lg p-5 shadow-hard hover:bg-green transition-colors"
          >
            <div class="text-2xl font-black">{section.title}</div>
            <p class="mt-2 opacity-70">{section.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
